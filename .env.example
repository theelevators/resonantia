# Resonantia — environment variables
# Copy this file to .env and fill in your values.
#
#   cp .env.example .env

# ── Frontend (baked into the static bundle at build time via Vite) ─────────────
# Your Clerk publishable key (pk_live_... for production)
VITE_CLERK_PUBLISHABLE_KEY=

# Public URL/path of your running gateway (no trailing slash).
# Recommended in docker compose: same-origin proxy path (no public gateway port required).
# Supported proxy aliases include /__gateway_proxy__ and /gateway_proxy.
VITE_GATEWAY_BASE_URL=/__gateway_proxy__

# Upstream used by the web server-side proxy for /__gateway_proxy__.
# Keep this internal Docker DNS so gateway stays private.
RESONANTIA_GATEWAY_UPSTREAM=http://resonantia-gateway:8090

# Optional: name of the Clerk JWT template that includes your gateway claims.
# Leave empty to use the default session token.
VITE_CLERK_GATEWAY_TOKEN_TEMPLATE=
# ── SurrealDB node storage ───────────────────────────────────────────────────
# These four vars together enable remote SurrealDB. Leave all empty to fall back
# to embedded surrealkv per-tenant files (single-instance only).
#
# In docker compose the endpoint uses the internal service name:
#   RESONANTIA_SURREALDB_ENDPOINT=ws://resonantia-surreal:8000
# For an external managed instance use wss://your-host:8000
RESONANTIA_SURREALDB_ENDPOINT=ws://resonantia-surreal:8000
RESONANTIA_SURREALDB_NS=resonantia
RESONANTIA_SURREALDB_USER=root
RESONANTIA_SURREALDB_PASS=change-me-strong-password
# ── Gateway ────────────────────────────────────────────────────────────────────
# Host port for the gateway container (container always binds 8090 internally)
GATEWAY_PORT=8090

# Host port for the web container (container always binds 4173 internally)
RESONANTIA_PORT=4173

# Comma-separated allowed CORS origins
RESONANTIA_GATEWAY_ALLOWED_ORIGINS=https://app.resonantia.me,https://account.resonantia.me

# Auth mode: "off" (header-based tenant) or "clerk" (Clerk JWT required)
RESONANTIA_GATEWAY_AUTH_MODE=off

# Required when AUTH_MODE=clerk — your Clerk issuer URL
RESONANTIA_GATEWAY_CLERK_ISSUER=

# Optional Clerk JWKS URL (defaults to <issuer>/.well-known/jwks.json)
RESONANTIA_GATEWAY_CLERK_JWKS_URL=

# Optional Clerk audience to validate
RESONANTIA_GATEWAY_CLERK_AUDIENCE=

# JWT claim to use as tenant ID.
# "sub" = per-user isolation (each Clerk user gets their own data namespace) — correct for Resonantia.
# "org_id" = per-org isolation (only if you use Clerk orgs).
RESONANTIA_GATEWAY_CLERK_TENANT_CLAIM=sub

# GHCR image registry config
GHCR_OWNER=your-github-username-or-org
IMAGE_TAG=latest

# JWKS cache TTL in seconds (default: 300)
RESONANTIA_GATEWAY_CLERK_JWKS_CACHE_SECONDS=300

# JWT clock-skew tolerance in seconds when validating exp/nbf (default: 60).
# Increase if your host clock drifts or distributed infrastructure has small time skew.
RESONANTIA_GATEWAY_CLERK_TOKEN_LEEWAY_SECONDS=60

# Allow header-based tenant fallback in clerk mode (default: false)
RESONANTIA_GATEWAY_ALLOW_TENANT_HEADER_FALLBACK=false

# Maximum tenant AppState instances held in gateway memory at once.
RESONANTIA_GATEWAY_MAX_CACHED_TENANTS=256

# Evict tenant AppState entries that have been idle this many seconds.
RESONANTIA_GATEWAY_TENANT_IDLE_TTL_SECONDS=1800

# Background cleanup cadence for evicting idle tenant AppState entries.
RESONANTIA_GATEWAY_TENANT_CACHE_CLEANUP_SECONDS=300

# Default tenant when no claim/header is present (default: public)
RESONANTIA_GATEWAY_DEFAULT_TENANT=public

# Admin secret — required to call PATCH /api/v1/account/tier
# Used internally by Stripe webhook handler and admin scripts.
RESONANTIA_GATEWAY_ADMIN_SECRET=change-me-in-production

# ── Stripe (all four required to enable payments; leave empty to disable) ───────
RESONANTIA_STRIPE_SECRET_KEY=
RESONANTIA_STRIPE_WEBHOOK_SECRET=
# Stripe Price ID for the Resonant tier ($4.99/mo — cloud sync)
RESONANTIA_STRIPE_PRICE_ID_RESONANT=
# Stripe Price ID for the Soulful tier ($8.99/mo — cloud sync + managed AI)
RESONANTIA_STRIPE_PRICE_ID_SOULFUL=
RESONANTIA_STRIPE_SUCCESS_URL=https://account.resonantia.me?payment=success
RESONANTIA_STRIPE_CANCEL_URL=https://account.resonantia.me?payment=cancelled

# ── Managed AI (gateway-side OpenAI) ─────────────────────────────────────────
# Managed key should only be configured on the gateway/server side.
# Clients call /api/v1/ai/chat on the gateway; key is never shipped to app/web.
RESONANTIA_OPENAI_API_KEY=
RESONANTIA_OPENAI_MODEL=gpt-4o-mini
RESONANTIA_OPENAI_BASE_URL=https://api.openai.com/v1

# If true, managed chat calls require soulful tier for authenticated users.
# Transmutation still allows Tauri desktop client requests by default.
RESONANTIA_AI_REQUIRE_SOULFUL_FOR_CHAT=true

# ── Logging ────────────────────────────────────────────────────────────────────
RUST_LOG=resonantia_gateway=info,tower_http=warn
