	private static InnerDialogue BuildInnerDialogue(PsychLayer psych, DeltaStory delta)
	{
		var analyst = psych.OrbClass switch
		{
			"orb-alert" => "This looks like a heavy moment. Make it simpler before you ask more from yourself.",
			"orb-focused" => "This looks like a good window for finishing one important thing.",
			"orb-connective" => "This looks like a moment where another person could help unlock progress.",
			_ => "This looks steady. Keep your rhythm and do not overcomplicate it."
		};

		var human = psych.OrbClass switch
		{
			"orb-alert" => "I want relief and permission to make this simpler.",
			"orb-focused" => "I want to finish something meaningful and feel proud of it.",
			"orb-connective" => "I want support and momentum that does not feel lonely.",
			_ => "I want progress that feels calm, not chaotic."
		};

		var synthesis = delta.Headline.Contains("stable", StringComparison.OrdinalIgnoreCase)
			? "Together: protect this steadiness by choosing one visible win and stopping on purpose."
			: "Together: choose one action that feels both useful and kind to yourself.";

		return new InnerDialogue(analyst, human, synthesis);
