	private static LifeContextTags BuildLifeContextTags(PsychLayer psych)
	{
		var curiosity = psych.Axes[0].Value;
		var discipline = psych.Axes[1].Value;
		var socialEnergy = psych.Axes[2].Value;
		var flexibility = psych.Axes[3].Value;
		var stressLoad = psych.Axes[4].Value;

		var tags = new List<LifeContextTag>();

		if (stressLoad >= 0.68f)
			tags.Add(new LifeContextTag("Recovery Mode", 0f));

		if (discipline >= 0.70f && stressLoad < 0.55f)
			tags.Add(new LifeContextTag("Deep Focus", 220f));
		else if (discipline >= 0.65f && stressLoad >= 0.55f)
			tags.Add(new LifeContextTag("Work Sprint", 270f));

		if (curiosity >= 0.68f && flexibility >= 0.58f)
			tags.Add(new LifeContextTag("Creative Flow", 38f));
		else if (curiosity >= 0.62f && discipline < 0.60f)
			tags.Add(new LifeContextTag("Exploration Phase", 160f));

		if (socialEnergy >= 0.66f)
			tags.Add(new LifeContextTag("Social Push", 145f));

		if (flexibility >= 0.62f && stressLoad < 0.48f && discipline >= 0.54f && !tags.Any(t => t.Label == "Deep Focus"))
			tags.Add(new LifeContextTag("Planning Mode", 200f));

		if (tags.Count == 0)
			tags.Add(new LifeContextTag("Steady State", 215f));

		string moodNote;
		if (tags.Count == 1)
		{
			moodNote = tags[0].Label switch
			{
				"Recovery Mode" => "Load is high — protect your energy and simplify the next move.",
				"Deep Focus" => "A clear execution window is open right now.",
				"Work Sprint" => "Pushing through with pressure behind you.",
				"Creative Flow" => "Curiosity and flexibility are converging — follow it.",
				"Exploration Phase" => "Curiosity is leading. Good moment to follow without forcing structure.",
				"Social Push" => "Connection energy is high. Good time to involve someone.",
				"Planning Mode" => "Adaptive structure available — map before you move.",
				_ => "Steady momentum — the state is sustainably balanced."
			};
		}
		else if (tags.Count == 2)
		{
			moodNote = $"Blending {tags[0].Label.ToLowerInvariant()} with {tags[1].Label.ToLowerInvariant()}.";
		}
		else
		{
			moodNote = $"Complex state: {string.Join(", ", tags.Take(3).Select(t => t.Label.ToLowerInvariant()))}.";
		}

		return new LifeContextTags(tags, moodNote);
	}

	private static BlindSpotLens BuildBlindSpotLens(PsychLayer psych)
	{
		var curiosity = psych.Axes[0].Value;
		var discipline = psych.Axes[1].Value;
		var socialEnergy = psych.Axes[2].Value;
		var flexibility = psych.Axes[3].Value;
		var stressLoad = psych.Axes[4].Value;

		var opportunities = new[]
		{
			("curiosity",     1f - curiosity),
			("discipline",    1f - discipline),
			("social energy", 1f - socialEnergy),
			("flexibility",   1f - flexibility),
			("stress load",   stressLoad)
		};

		var strongest = opportunities.OrderByDescending(o => o.Item2).First();

		if (strongest.Item2 < 0.18f)
			return new BlindSpotLens(
				"Coherence Balance",
				"Your state is unusually aligned — which makes it easy to drift without noticing.",
				"Name one priority so this steady moment turns into progress, not drift.");

		return strongest.Item1 switch
		{
			"curiosity" => new BlindSpotLens(
				"Curiosity Gap",
				"You may be solving the known problem instead of questioning whether it is the right one.",
				"Ask one question you have not asked yet about this situation."),
			"discipline" => new BlindSpotLens(
				"Commitment Gap",
				"You may be circling without committing. One locked action beats ten open loops.",
				"Name one specific thing you can finish and hold yourself to."),
			"social energy" => new BlindSpotLens(
				"Connection Gap",
				"You may be going it alone when a conversation would accelerate the work.",
				"Share one update or ask one question that could help move this forward."),
			"flexibility" => new BlindSpotLens(
				"Flexibility Gap",
				"You may be attached to a path that has already shifted beneath you.",
				"Name one assumption you may be protecting and test it quickly."),
			_ => new BlindSpotLens(
				"Stress Buildup",
				"You may be carrying more than you are fully noticing.",
				"Before you add more, finish or drop one thing from your list.")
		};
	}

	private static string GetContextTagStyle(LifeContextTag tag)
		=> string.Create(CultureInfo.InvariantCulture, $"--tag-hue:{tag.Hue:0};");

	private static GentleCelebration BuildGentleCelebration(SessionGroup session, PsychLayer psych, DeltaStory delta)
	{
		var curiosity  = psych.Axes[0].Value;
		var discipline = psych.Axes[1].Value;
		var stressLoad = psych.Axes[4].Value;
		var coherence  = psych.Coherence;

		// Milestone: large session (8+ nodes)
		if (session.Nodes.Count >= 8)
			return new GentleCelebration(true, "∞",
				"Deep Continuity",
				$"This session has {session.Nodes.Count} moments — a rare depth of tracking. That's worth acknowledging.");

		// Coherence spike
		if (coherence >= 0.78f)
			return new GentleCelebration(true, "◎",
				"High Coherence",
				"Your state is unusually aligned right now. Most people never notice moments like this. You did.");

		// Stress came down noticeably
		if (delta.Headline.Contains("stress load", StringComparison.OrdinalIgnoreCase)
			&& delta.Headline.Contains("dropped", StringComparison.OrdinalIgnoreCase))
			return new GentleCelebration(true, "▽",
				"Pressure Released",
				"Your stress signal dropped between moments. That shift took something. It counts.");

		// High discipline + low stress = execution window
		if (discipline >= 0.74f && stressLoad < 0.40f)
			return new GentleCelebration(true, "⬡",
				"Clear Execution Window",
				"High discipline and low pressure rarely show up together. This is a good moment to do the hard thing.");

		// Curiosity peak
		if (curiosity >= 0.76f)
			return new GentleCelebration(true, "✦",
				"Curiosity Peak",
				"Your curiosity signal is at a high. Ideas are more accessible now than they usually are.");

		return new GentleCelebration(false, string.Empty, string.Empty, string.Empty);
	}

	private static JournalExportEntry BuildJournalExport(
		SessionGroup session,
		NodeDto focusNode,
		PsychLayer psych,
		DailyArchetypeCard archetype,
		DeltaStory delta,
		LifeContextTags contextTags,
		BlindSpotLens blindSpot)
	{
		var dateLine = $"{focusNode.Timestamp:yyyy-MM-dd} · {session.SessionId}";
		var stateLine = $"Moment: {psych.Archetype}";
		var contextLine = contextTags.Tags.Count > 0
			? $"What stands out: {string.Join(", ", contextTags.Tags.Select(t => t.Label))}"
			: "What stands out: Steady State";
		var deltaLine = $"What changed: {delta.Headline}";
		var blindSpotLine = $"What to watch: {blindSpot.Label} — {blindSpot.Nudge}";
		var descLine = archetype.Description;

		var lines = new[] { dateLine, stateLine, contextLine };
		var fullText = string.Join("\n",
			dateLine, stateLine, contextLine, deltaLine, descLine, blindSpotLine);

		return new JournalExportEntry(lines, fullText);
	}

	private static RecommendedAction BuildRecommendedAction(
		PsychLayer psych,
		DeltaStory delta,
		BlindSpotLens blindSpot,
		LifeContextTags contextTags)
	{
		var action = psych.OrbClass switch
		{
			"orb-alert" => "Make the day lighter: drop, delay, or hand off one thing.",
			"orb-focused" => "Pick one meaningful thing and finish it end to end.",
			"orb-connective" => "Send one clear message that helps this move forward.",
			_ => "Choose one visible next step and give it a clear finish line."
		};

		var why = $"This matters most right now because {blindSpot.Label.ToLowerInvariant()} is where the most movement is available. " +
			(delta.Headline.Contains("stable", StringComparison.OrdinalIgnoreCase)
				? "It helps this moment turn into progress instead of drift."
				: "It helps turn this shift into something useful.");

		if (contextTags.Tags.Any(t => t.Label == "Recovery Mode"))
			why = "This feels like a recovery moment. Make it lighter before you make it bigger.";

		return new RecommendedAction(action, why);
	}

	private async Task CopyJournalAsync(string text)
	{
		if (string.IsNullOrWhiteSpace(text)) return;
		await JS.InvokeVoidAsync("navigator.clipboard.writeText", text);
		journalCopied = true;
		StateHasChanged();
		await Task.Delay(1800);
		journalCopied = false;
		StateHasChanged();
	}

	private void JumpToSession(string sessionId)
	{
		var idx = sessions.FindIndex(s => s.SessionId == sessionId);
		if (idx < 0) return;
		var previousIndex = currentSessionIndex;
		currentSessionIndex = idx;
		currentSessionNodeIndex = 0;
		slideClass = idx > previousIndex ? "from-right" : "from-left";
		showReferences = false;
		showDetail = IsInspectMode;
		nodeKey = GetSessionKey(sessions[currentSessionIndex]);
		shouldAttachSwipe = true;
	}

	private static RadarPoint PolarPoint(int index, float value, float radius)
	{
		var angle = (-90d + index * 72d) * Math.PI / 180d;
		var r = radius * Clamp01(value);
		var x = 110d + Math.Cos(angle) * r;
		var y = 110d + Math.Sin(angle) * r;
		return new RadarPoint((float)x, (float)y);
	}

	private static float Clamp01(float value)
		=> Math.Clamp(value, 0f, 1f);

