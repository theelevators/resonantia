	private async Task RunSafeAsync(Func<Task> work)
	{
		isWorking = true;
		try
		{
			await work();
		}
		catch (Exception ex)
		{
			healthText = $"error: {ex.Message}";
			healthClass = "status-bad";
		}
		finally
		{
			isWorking = false;
		}
	}

	public async ValueTask DisposeAsync()
	{
		_dotNetRef?.Dispose();
		try
		{
			if (_swipeModule is not null)
				await _swipeModule.DisposeAsync();
			if (_graphModule is not null)
			{
				await _graphModule.InvokeVoidAsync("destroySessionGraph", "sttp-graph");
				await _graphModule.DisposeAsync();
			}
			if (_themeModule is not null)
				await _themeModule.DisposeAsync();
		}
		catch (JSDisconnectedException) { }
	}
