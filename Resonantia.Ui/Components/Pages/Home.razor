	private static DeltaStory BuildDeltaStory(SessionGroup session, int currentNodeIdx)
	{
		if (session.Nodes.Count < 2 || currentNodeIdx >= session.Nodes.Count - 1)
			return new DeltaStory(
				"This is the newest moment in this session.",
				"Add another moment later and this space will show what shifted.");

		var current = ResolveState(session.Nodes[currentNodeIdx]);
		var previous = ResolveState(session.Nodes[currentNodeIdx + 1]);

		var deltas = new List<(string Name, float Value)>
		{
			("curiosity", (current.Logic * 0.58f + current.Autonomy * 0.42f) - (previous.Logic * 0.58f + previous.Autonomy * 0.42f)),
			("discipline", (current.Stability * 0.64f + (1f - current.Friction) * 0.36f) - (previous.Stability * 0.64f + (1f - previous.Friction) * 0.36f)),
			("social energy", (current.Autonomy * 0.56f + (1f - current.Friction) * 0.44f) - (previous.Autonomy * 0.56f + (1f - previous.Friction) * 0.44f)),
			("flexibility", ((1f - current.Stability) * 0.34f + current.Logic * 0.36f + current.Autonomy * 0.30f) - ((1f - previous.Stability) * 0.34f + previous.Logic * 0.36f + previous.Autonomy * 0.30f)),
			("stress load", (current.Friction * 0.74f + (1f - current.Stability) * 0.26f) - (previous.Friction * 0.74f + (1f - previous.Stability) * 0.26f))
		};

		var strongestUp = deltas.OrderByDescending(d => d.Value).First();
		var strongestDown = deltas.OrderBy(d => d.Value).First();
		var upText = strongestUp.Value > 0.02f ? $"{strongestUp.Name} rose {ToPercent(Math.Abs(strongestUp.Value))}%" : null;
		var downText = strongestDown.Value < -0.02f ? $"{strongestDown.Name} dropped {ToPercent(Math.Abs(strongestDown.Value))}%" : null;

		var headline = upText is not null && downText is not null
			? $"{upText}, while {downText}."
			: upText is not null
				? upText + "."
				: downText is not null
					? downText + "."
					: "Not much moved between these last two moments.";

		var supporting = upText is not null || downText is not null
			? "Treat this as direction, not a verdict on you."
			: "Small changes are normal. Patterns get clearer over time.";

		return new DeltaStory(headline, supporting);
	}

	private static IReadOnlyList<string> BuildAdaptivePrompts(PsychLayer psych, DeltaStory delta)
	{
		var prompts = new List<string>(3);

		if (psych.OrbClass == "orb-alert")
			prompts.Add("What can I safely remove from my plate in the next 10 minutes?");
		else if (psych.OrbClass == "orb-focused")
			prompts.Add("What single commitment will convert this focus into visible progress?");
		else if (psych.OrbClass == "orb-connective")
			prompts.Add("Who could make this easier if I reached out right now?");
		else
			prompts.Add("What one tiny step would keep this balanced state alive?");

		prompts.Add(delta.Headline.Contains("rose", StringComparison.OrdinalIgnoreCase)
			? "How can I channel this rising energy without overloading myself?"
			: "What support would help me lift the quieter part of my state?");

		prompts.Add("If tomorrow felt 15% better, what would I do differently first?");

		return prompts;
	}

	private static IReadOnlyList<MoodTimelineItem> BuildMoodTimeline(IReadOnlyList<SessionGroup> groups, int currentIdx)
	{
		return groups.Take(12).Select((g, idx) =>
		{
			var psych = BuildPsychLayer(g.LatestNode);
			return new MoodTimelineItem(
				g.SessionId,
				idx == currentIdx,
				psych.OrbHue,
				Math.Clamp(0.42f + psych.OrbEnergy * 0.5f, 0.38f, 0.94f),
				$"{g.SessionId} · {psych.Archetype}");
		}).ToList();
	}

