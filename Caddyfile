(security_headers) {
    header {
        Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
        X-Content-Type-Options nosniff
        X-Frame-Options DENY
        Referrer-Policy no-referrer-when-downgrade
    }
}

(block_disallowed_bots) {
    @disallowed_bots {
        header_regexp User-Agent (?i)(GPTBot|ChatGPT-User|Google-Extended)
    }

    handle @disallowed_bots {
        abort
    }
}

app.resonantia.me {
    import block_disallowed_bots

    encode zstd gzip

    # Proxy-prefixed gateway calls from the web client.
    handle_path /__gateway_proxy__/* {
        reverse_proxy resonantia-gateway:8090
    }

    handle_path /gateway_proxy/* {
        reverse_proxy resonantia-gateway:8090
    }

    handle_path /gateway/* {
        reverse_proxy resonantia-gateway:8090
    }

    handle {
        reverse_proxy resonantia-web:4173
    }

    import security_headers
}

account.resonantia.me {
    import block_disallowed_bots

    # Root should redirect so browser URL is /account (SPA route), not just upstream rewrite.
    @account_root path /
    redir @account_root /account 308

    encode zstd gzip

    # Proxy-prefixed gateway calls from the web client.
    handle_path /__gateway_proxy__/* {
        reverse_proxy resonantia-gateway:8090
    }

    handle_path /gateway_proxy/* {
        reverse_proxy resonantia-gateway:8090
    }

    handle_path /gateway/* {
        reverse_proxy resonantia-gateway:8090
    }

    handle {
        reverse_proxy resonantia-web:4173
    }

    import security_headers
}

api.resonantia.me, gateway.resonantia.me {
    # Explicit webhook route (Stripe posts here).
    handle /stripe/webhook {
        reverse_proxy resonantia-gateway:8090
    }

    # All other gateway API routes.
    handle {
        reverse_proxy resonantia-gateway:8090
    }

    import security_headers
}