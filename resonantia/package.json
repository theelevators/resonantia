{
  "name": "resonantia",
  "version": "0.1.0",
  "description": "",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "vite dev",
    "dev:lan": "vite dev --host 0.0.0.0 --port 1420 --strictPort",
    "build": "vite build",
